{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skill Rules Configuration",
  "description": "Defines trigger rules for automatic skill activation based on keywords, patterns, and file paths.",
  "rules": [
    {
      "skill": "shell-script-quality",
      "triggers": {
        "keywords": ["shell", "bash", "script", "shellcheck", "bats"],
        "patterns": ["\\.sh$", "^(#!.*bash)", "^(#!.*sh)"],
        "files": ["**/*.sh", "scripts/**/*"]
      },
      "priority": "high",
      "autoActivate": true
    },
    {
      "skill": "task-decomposition",
      "triggers": {
        "keywords": [
          "plan",
          "decompose",
          "break down",
          "steps",
          "phases",
          "milestone"
        ],
        "patterns": ["plan.*", "step.*", "phase.*"],
        "files": []
      },
      "priority": "high",
      "autoActivate": true
    },
    {
      "skill": "code-quality",
      "triggers": {
        "keywords": [
          "review",
          "quality",
          "refactor",
          "clean code",
          "best practice"
        ],
        "patterns": ["review.*", "quality.*", "refactor.*"],
        "files": ["**/*.rs", "**/*.ts", "**/*.js", "**/*.py", "**/*.go"]
      },
      "priority": "medium",
      "autoActivate": false
    },
    {
      "skill": "test-runner",
      "triggers": {
        "keywords": [
          "test",
          "spec",
          "coverage",
          "unit test",
          "integration test"
        ],
        "patterns": ["test.*", "spec.*", ".*_test\\.", ".*\\.test\\."],
        "files": ["**/tests/**/*", "**/*.test.*", "**/*_test.*"]
      },
      "priority": "high",
      "autoActivate": true
    },
    {
      "skill": "parallel-execution",
      "triggers": {
        "keywords": ["parallel", "concurrent", "simultaneous", "batch"],
        "patterns": ["parallel.*", "concurrent.*"],
        "files": []
      },
      "priority": "medium",
      "autoActivate": false
    },
    {
      "skill": "iterative-refinement",
      "triggers": {
        "keywords": ["iterate", "refine", "improve", "loop", "progressive"],
        "patterns": ["iterate.*", "refine.*", "improve.*"],
        "files": []
      },
      "priority": "medium",
      "autoActivate": false
    },
    {
      "skill": "web-search-researcher",
      "triggers": {
        "keywords": [
          "search",
          "research",
          "find information",
          "look up",
          "documentation"
        ],
        "patterns": ["search.*", "research.*", "find.*"],
        "files": []
      },
      "priority": "medium",
      "autoActivate": false
    }
  ],
  "settings": {
    "maxSkillsPerTask": 3,
    "cooldownPeriod": 300,
    "requireUserConfirmation": false
  }
}

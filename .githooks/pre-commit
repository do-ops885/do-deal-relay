#!/bin/bash
#
# Pre-commit Guard Rails Hook
# Prevents committing dangerous or incorrect files
#

set -e

echo "🛡️  Running pre-commit guard rails..."

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ERRORS=0
WARNINGS=0

# Function to print error
error() {
    echo -e "${RED}✗${NC} $1"
    ERRORS=$((ERRORS + 1))
}

# Function to print warning  
warning() {
    echo -e "${YELLOW}⚠${NC} $1"
    WARNINGS=$((WARNINGS + 1))
}

# Function to print success
success() {
    echo -e "${GREEN}✓${NC} $1"
}

# Get list of files to be committed
FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$FILES" ]; then
    success "No files to commit"
    exit 0
fi

echo "Checking ${#FILES[@]} files..."
echo ""

# GUARD RAIL 1: Blocked File Patterns
echo "Guard Rail 1: Blocked File Patterns"
BLOCKED_PATTERNS=(
    "\.env$"
    "\.env\."
    "\.key$"
    "\.pem$"
    "\.p12$"
    "\.pfx$"
    "id_rsa"
    "id_dsa"
    "id_ecdsa"
    "id_ed25519"
    "\.keystore$"
    "\.jks$"
    "credentials"
    "password"
    "secret"
    "token"
    "api_key"
    "private_key"
)

for file in $FILES; do
    for pattern in "${BLOCKED_PATTERNS[@]}"; do
        if echo "$file" | grep -qE "$pattern"; then
            error "Blocked file pattern detected: $file (matches: $pattern)"
            echo "   Remove this file from staging: git reset HEAD $file"
        fi
    done
done

if [ $ERRORS -eq 0 ]; then
    success "No blocked file patterns found"
fi
echo ""

# GUARD RAIL 2: Secret Detection
echo "Guard Rail 2: Secret Detection"
SECRET_PATTERNS=(
    "ghp_[a-zA-Z0-9]{36}"  # GitHub personal access token
    "gho_[a-zA-Z0-9]{36}"  # GitHub OAuth token
    "github_pat_[a-zA-Z0-9]{22}_[a-zA-Z0-9]{59}"  # GitHub fine-grained PAT
    "sk-[a-zA-Z0-9]{48}"   # OpenAI/Stripe secret key
    "sk_live_[a-zA-Z0-9]{24,}"  # Stripe live key
    "sk_test_[a-zA-Z0-9]{24,}"  # Stripe test key
    "AKIA[0-9A-Z]{16}"     # AWS Access Key ID
    "[0-9a-zA-Z/+]{40}"    # AWS Secret Access Key (generic)
    "ya29\\.[0-9A-Za-z_-]+" # Google OAuth token
    "[0-9a-f]{32}-us[0-9]{2}" # Mailchimp API key
    "sq0csp-[0-9a-zA-Z_-]{43}" # Square OAuth secret
    "sq0idp-[0-9a-zA-Z_-]{43}" # Square OAuth ID
)

for file in $FILES; do
    # Skip binary files and large files
    if [ -f "$file" ] && [ ! -d "$file" ]; then
        # Check file size (skip files > 1MB)
        filesize=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null || echo 0)
        if [ "$filesize" -lt 1048576 ]; then
            for pattern in "${SECRET_PATTERNS[@]}"; do
                if git show :"$file" 2>/dev/null | grep -qE "$pattern"; then
                    error "Potential secret detected in: $file"
                    echo "   Pattern matched: ${pattern:0:30}..."
                    echo "   Review and remove before committing"
                fi
            done
        fi
    fi
done

if [ $ERRORS -eq 0 ]; then
    success "No secrets detected"
fi
echo ""

# GUARD RAIL 3: File Size Limits
echo "Guard Rail 3: File Size Limits"
MAX_SIZE=$((500 * 1024))  # 500KB

for file in $FILES; do
    if [ -f "$file" ] && [ ! -d "$file" ]; then
        filesize=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null || echo 0)
        if [ "$filesize" -gt "$MAX_SIZE" ]; then
            size_kb=$((filesize / 1024))
            error "File too large: $file (${size_kb}KB > 500KB limit)"
            echo "   Consider using git-lfs for large files"
        fi
    fi
done

if [ $ERRORS -eq 0 ]; then
    success "All files within size limits"
fi
echo ""

# GUARD RAIL 4: Line Count Limits (TypeScript/JavaScript files only)
echo "Guard Rail 4: Line Count Limits"
MAX_LINES=500

for file in $FILES; do
    if [[ $file =~ \.(ts|js|tsx|jsx)$ ]] && [ -f "$file" ]; then
        lines=$(wc -l < "$file" | tr -d ' ')
        if [ "$lines" -gt "$MAX_LINES" ]; then
            warning "File exceeds 500 lines: $file ($lines lines)"
            echo "   Consider splitting into smaller modules"
        fi
    fi
done

success "Line count check complete"
echo ""

# GUARD RAIL 5: Prevent Committing node_modules
echo "Guard Rail 5: Dependency Directory Check"
for file in $FILES; do
    if [[ $file == node_modules/* ]] || [[ $file == */node_modules/* ]]; then
        error "Attempting to commit node_modules file: $file"
        echo "   Add node_modules to .gitignore"
    fi
    if [[ $file == .wrangler/* ]] || [[ $file == .next/* ]] || [[ $file == dist/* ]] || [[ $file == build/* ]]; then
        error "Attempting to commit build output: $file"
        echo "   Add to .gitignore: ${file%%/*}/"
    fi
done

if [ $ERRORS -eq 0 ]; then
    success "No dependency/build files staged"
fi
echo ""

# GUARD RAIL 6: Trailing Whitespace
echo "Guard Rail 6: Code Quality"
for file in $FILES; do
    if [[ $file =~ \.(ts|js|tsx|jsx|json|md|yml|yaml|toml|sh)$ ]] && [ -f "$file" ]; then
        if git show :"$file" 2>/dev/null | grep -q '[[:space:]]$'; then
            warning "Trailing whitespace in: $file"
            echo "   Run: sed -i 's/[[:space:]]*$//' $file"
        fi
    fi
done

success "Code quality check complete"
echo ""

# GUARD RAIL 7: Syntax Validation (JSON only)
echo "Guard Rail 7: Syntax Validation"
for file in $FILES; do
    if [[ $file =~ \.json$ ]] && [ -f "$file" ]; then
        if ! git show :"$file" 2>/dev/null | jq . > /dev/null 2>&1; then
            error "Invalid JSON syntax in: $file"
        fi
    fi
done

if [ $ERRORS -eq 0 ]; then
    success "All JSON files are valid"
fi
echo ""

# Summary
echo "=================================="
echo "Guard Rails Summary"
echo "=================================="
echo "Errors: $ERRORS"
echo "Warnings: $WARNINGS"
echo ""

if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}✗ COMMIT BLOCKED${NC}"
    echo "Fix the errors above before committing."
    echo ""
    echo "To bypass (not recommended): git commit --no-verify"
    exit 1
elif [ $WARNINGS -gt 0 ]; then
    echo -e "${YELLOW}⚠ COMMIT ALLOWED WITH WARNINGS${NC}"
    echo "Review warnings above."
    exit 0
else
    echo -e "${GREEN}✓ ALL GUARD RAILS PASSED${NC}"
    exit 0
fi

#!/bin/bash
#
# Commit Message Validation Hook
# Ensures commit messages follow conventions
#

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Get the commit message file
COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# Skip for merge commits, squash commits, etc.
if [ -n "$COMMIT_SOURCE" ]; then
    exit 0
fi

# Read the commit message
COMMIT_MSG=$(head -n1 "$COMMIT_MSG_FILE")

ERRORS=0
error() {
    echo -e "${RED}✗${NC} $1"
    ERRORS=$((ERRORS + 1))
}

success() {
    echo -e "${GREEN}✓${NC} $1"
}

warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

echo "📝 Validating commit message..."
echo "Message: $COMMIT_MSG"
echo ""

# Check 1: Message length
if [ ${#COMMIT_MSG} -lt 10 ]; then
    error "Commit message too short (${#COMMIT_MSG} chars). Minimum 10 characters."
fi

if [ ${#COMMIT_MSG} -gt 72 ]; then
    error "Commit message exceeds 72 characters (${#COMMIT_MSG} chars). Must be 72 or fewer."
fi

# Check 2: Conventional Commits format
# Format: type(scope): description
CONVENTIONAL_PATTERN="^(feat|fix|docs|style|refactor|test|chore|ci|build|perf)(\(.+\))?: .+$"
if [[ ! $COMMIT_MSG =~ $CONVENTIONAL_PATTERN ]]; then
    error "Commit message doesn't follow conventional commits format"
    echo "   Expected: type(scope): description"
    echo "   Types: feat, fix, docs, style, refactor, test, chore, ci, build, perf"
    echo "   Example: feat(discovery): add support for new source"
else
    success "Follows conventional commits format"
fi

# Check 3: No WIP/draft markers in final commits
if [[ $COMMIT_MSG =~ ^(WIP|wip|DRAFT|draft|TMP|tmp|TEMP|temp) ]]; then
    error "Commit message starts with WIP/draft marker"
    echo "   Remove WIP markers before final commit"
fi

# Check 4: No trailing periods in subject
if [[ $COMMIT_MSG =~ \.$ ]]; then
    error "Commit message ends with period - remove trailing period"
fi

# Check 5: Description must start with uppercase (after type(scope):)
# Extract the description part after the colon and space
if [[ $COMMIT_MSG =~ ^[^:]+:\ ([^ ].*)$ ]]; then
    DESCRIPTION="${BASH_REMATCH[1]}"
    if [[ $DESCRIPTION =~ ^[a-z] ]]; then
        error "Description starts with lowercase - must start with uppercase"
        echo "   Change: '${DESCRIPTION:0:1}' → '$(echo "${DESCRIPTION:0:1}" | tr '[:lower:]' '[:upper:]')'"
        ERRORS=$((ERRORS + 1))
    fi
fi

# Check 6: No merge conflict markers
if grep -qE "^<{7}|^={7}|^>{7}" "$COMMIT_MSG_FILE"; then
    error "Merge conflict markers found in commit message!"
    echo "   Resolve all conflicts before committing"
fi

echo ""

# Summary
if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}✗ COMMIT MESSAGE ISSUES${NC}"
    echo "Fix the errors above or use: git commit --no-verify"
    exit 1
else
    success "Commit message validation passed"
    exit 0
fi

# ESLint Ignore Patterns
# Files and directories that ESLint should not lint

# Dependencies
node_modules/

# Build outputs
dist/
build/
*.tsbuildinfo

# Generated files
*.generated.ts
*.generated.js

# Minified files
*.min.js
*.min.css

# Test coverage
coverage/
.nyc_output/

# Temporary files
*.tmp
.tmp/
temp/

# Vendor directories
vendor/
third_party/

# Scripts (may have different standards)
scripts/*.sh
